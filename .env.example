# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-6
ANTHROPIC_MODEL_HIGHEST=claude-opus-4-7

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
# New-style publishable key (sb_publishable_...) OR legacy anon JWT. Either works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional but recommended for production: new-style secret key (sb_secret_...) or legacy service role JWT.
# If omitted, the server falls back to the publishable key (fine while RLS is off).
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Judge0 via RapidAPI (code execution sandbox)
JUDGE0_RAPIDAPI_KEY=
JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Tavily — web search probe for the plag check. Optional; if missing, the
# plag check only uses the local corpus.
TAVILY_API_KEY=

# Plag tuning — fuzzball token_set_ratio above this threshold (0–1) flags a match.
# 0.85 catches exact + minor edits; raise toward 1.0 to be stricter.
PLAG_FUZZ_THRESHOLD=0.85
