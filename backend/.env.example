# Leave ANTHROPIC_API_KEY unset to use the bundled Claude Code CLI's own
# session auth (i.e. whatever `claude` itself is logged in as). If you set
# this to anything other than a real API key, the CLI will reject it.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# Optional: pin language toolchains. Leave blank to use PATH defaults.
PYTHON_BIN=python3
NODE_BIN=node
JAVAC_BIN=javac
JAVA_BIN=java
CPP_BIN=g++

# Code execution timeout (seconds)
CODE_RUN_TIMEOUT=8
